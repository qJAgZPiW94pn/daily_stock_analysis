          "categories"
        ]
      },
      "SystemConfigItem": {
        "type": "object",
        "description": "系統配置项（含脱敏顯示值）",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "description": "当前配置值（敏感欄位傳回真实值）"
          },
          "raw_value_exists": {
            "type": "boolean",
            "description": "敏感欄位是否存在真实值（不傳回真实值）"
