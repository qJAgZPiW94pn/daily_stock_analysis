# ===================================
# A股自选股智能分析系統 - 環境變數配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================

# 自选股列表（逗号分隔，支援滬深两市代碼）
# 沪市：600xxx, 601xxx, 603xxx
# 深市：000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API Keys（支援多个，逗号分隔）
# 獲取: https://open.anspire.cn/?share_code=QFBC0FYC
# 在未配置更高優先级 OpenAI-compatible 来源时，满足條件可复用该 key 给 Anspire 大模型网关与新闻搜尋。
# 下列网关与模型为当前项目示例配置；是否可用请以 Anspire 控制台与官方文档为准：
# 示例网关： https://open-gateway.anspire.cn/v6
# 示例模型：Doubao-Seed-2.0-lite（可覆盖为 ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro）
# 若网关有区域/版本差异，可覆盖为 ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# 數據源配置
# Tushare Pro Token（可選，从 https://tushare.pro/weborder/#/login?reg=834638 獲取）
TUSHARE_TOKEN=
# TickFlow API Key（可選，用于 A 股大盤复盘指數增强；若套餐支援标的池查詢，也可增强市场統計）
# TICKFLOW_API_KEY=

# Finnhub（可選，美股數據源，免费 tier 60 calls/min）
# 獲取: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage（可選，美股數據源，免费 tier 25 calls/day）
# 獲取: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI（可選，美股/港股量比、换手率、PE 等欄位兜底）
# 从 https://open.longbridge.com/ 獲取
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info 程式内快取秒数，預設 86400；0=每次請求拉取
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# 連線關閉类例外后的冷却秒数，預設 15；冷却期内会暫時略過 Longbridge，避免請求级頻繁重连
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK 语言与 REPORT_LANGUAGE（zh/en）一致；SDK 日誌写入 LOG_DIR/longbridge_sdk.log
# 接入点（与 REPORT_LANGUAGE 无关；留空则用下列預設值）：
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# 覆盖接入点；SDK 内部用 LONGPORT_REGION（不带 BRIDGE）自动选择，
# 代碼会自动同步 LONGBRIDGE_REGION → LONGPORT_REGION。
# hk → *.longbridge.com  |  cn → *.longbridge.cn
# 其余见：https://open.longbridge.com/zh-CN/docs/getting-started#環境變數
# 夜盘行情 true/false，預設 false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K 线推送 realtime 或 confirmed，預設 realtime
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# 連線时是否打印行情包（与 README / full-guide 一致：未设置时应用侧預設为關閉，等同 false）
# 设为 1 / true / yes 开启 SDK 詳細行情包日誌（调试长桥連線时使用）
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# ===================================
# AI 模型配置
# ===================================
# 完整说明：docs/LLM_CONFIG_GUIDE.md
#
# 【快速上手】填一个 API Key 即可執行，系統自动识别模型。
#   Anspire Open（一站式模型+搜尋）→ 填 ANSPIRE_API_KEYS
#   Gemini（免费額度）→ 填 GEMINI_API_KEY
#   DeepSeek（性价比高）→ 填 DEEPSEEK_API_KEY
#   AIHubmix（聚合平台）→ 填 AIHUBMIX_KEY
#
# 【进阶】需要多模型 / 多平台 fallback → 配置下方「多渠道」或在 Web 设置页可视化管理。
# ===================================

# --- API Key（填一个即可）---

# Gemini（https://aistudio.google.com）
GEMINI_API_KEY=
# 多 Key 负载均衡：GEMINI_API_KEYS=key1,key2,key3

# DeepSeek（https://platform.deepseek.com）
# 相容預設：仅填 DEEPSEEK_API_KEY 时仍使用 deepseek-chat，并在日誌提示迁移到 deepseek-v4-flash
# DEEPSEEK_API_KEY=

# AIHubmix 聚合（https://aihubmix.com/?aff=CfMq）
# 一个 Key 用 GPT/Claude/Gemini/GLM/Qwen 等模型，無需科学上网
# AIHUBMIX_KEY=

# Anthropic Claude（https://console.anthropic.com）
# ANTHROPIC_API_KEY=

# OpenAI / 相容 API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                     # 第三方 API 地址（中转站/代理），留空用官方

# Ollama 本機模型（無需 API Key，推荐）
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# 或使用渠道模式：
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# 採樣温度（0.0-2.0，預設 0.7；0 確定性最高，2 隨機性最高）
# 严格 temperature 相容来源：
# - Moonshot API / 模型文档：https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# - Moonshot 官方模型卡（评测預設 temperature = 1.0）：https://huggingface.co/moonshotai/Kimi-K2.6
# - OpenAI Chat Completions 規範：https://platform.openai.com/docs/api-reference/chat/create
# - LiteLLM OpenAI-Compatible 規範：https://docs.litellm.ai/docs/providers/openai_compatible
# 当前倉庫執行时依賴約束：litellm>=1.80.10,!=1.82.7,!=1.82.8,<2.0.0（显式排除 PyPI 事故版本，见 requirements.txt）。
# 因此 kimi-k2.6 会自动改用 1.0/0.6；GPT-5 / o 系列等預設温度模型会省略 temperature，避免 API 拒絕請求。
# 若相容平台傳回明確的參數不支援錯誤，執行时会在当前請求内修正參數并重試一次；成功策略只做程式内快取。
# top_p、presence_penalty、frequency_penalty、seed 若傳回“不支援參數”，同样会触发本次請求級別的修正与重試（不改写 LLM_TEMPERATURE）。
# 其他模型和 fallback 仍使用你配置的 LLM_TEMPERATURE。
# Web 设置页 / 桌面端匯入不会静默清空或改写 LLM_TEMPERATURE；只在真正发請求前暫時適配模型參數。
# 如果主模型切回普通模型，原本配置的温度会自动恢復；最小回滚方式是回退本次 LLM 參數適配改动。
# LLM_TEMPERATURE=0.7

# --- 多渠道配置（可選，也可在 Web 设置页配置）---
# 每个渠道独立配置 base_url / api_key / models，支援多 Key 轮询与自动 fallback。
#
# 示例：DeepSeek + Gemini 双渠道
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview
#
# 示例：自定义 API 端点（第三方代理 / 聚合平台 / 轉發站）
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6
# LLM_MY_PROXY_PROTOCOL=openai
#
# 示例：Ollama 本機模型（無需 API Key）
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2
#
# 常用厂商模板（任选其一复制到 .env；完整说明见 docs/llm-providers.md）
#
# Anspire Open（共享搜尋与 LLM Key，OpenAI Compatible）
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6（示例）
# LLM_ANSPIRE_API_KEY=sk-xxx
# LLM_ANSPIRE_MODELS=Doubao-Seed-2.0-lite,Doubao-Seed-2.0-pro（示例模型）
# LITELLM_MODEL=openai/Doubao-Seed-2.0-lite（示例）
#
# AIHubmix 聚合平台（OpenAI Compatible）
# LLM_CHANNELS=aihubmix
# LLM_AIHUBMIX_PROTOCOL=openai
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxx
# LLM_AIHUBMIX_MODELS=gpt-5.5,claude-sonnet-4-6,gemini-3.1-pro-preview
# LITELLM_MODEL=openai/gpt-5.5
#
# OpenAI 官方
# LLM_CHANNELS=openai
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_MODELS=gpt-5.5,gpt-5.4-mini
# LITELLM_MODEL=openai/gpt-5.5
#
# DeepSeek 官方
# LLM_CHANNELS=deepseek
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LITELLM_MODEL=deepseek/deepseek-v4-flash
#
# Gemini 官方（官方協議，Base URL 留空）
# LLM_CHANNELS=gemini
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-3.1-pro-preview
#
# Anthropic Claude 官方（官方協議，Base URL 留空）
# LLM_CHANNELS=anthropic
# LLM_ANTHROPIC_PROTOCOL=anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-7
# LITELLM_MODEL=anthropic/claude-sonnet-4-6
#
# Kimi / Moonshot（OpenAI Compatible）
# LLM_CHANNELS=moonshot
# LLM_MOONSHOT_PROTOCOL=openai
# LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# LLM_MOONSHOT_API_KEY=sk-xxx
# LLM_MOONSHOT_MODELS=kimi-k2.6,kimi-k2.5
# LITELLM_MODEL=openai/kimi-k2.6
#
# 通义千问 DashScope（OpenAI Compatible）
# LLM_CHANNELS=dashscope
# LLM_DASHSCOPE_PROTOCOL=openai
# LLM_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DASHSCOPE_API_KEY=sk-xxx
# LLM_DASHSCOPE_MODELS=qwen3.6-plus,qwen3.6-flash
# LITELLM_MODEL=openai/qwen3.6-plus
#
# 智谱 GLM（OpenAI Compatible）
# LLM_CHANNELS=zhipu
# LLM_ZHIPU_PROTOCOL=openai
# LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_API_KEY=xxx
# LLM_ZHIPU_MODELS=glm-5.1,glm-4.7-flash
# LITELLM_MODEL=openai/glm-5.1
#
# MiniMax（OpenAI Compatible）
# 来源：官方 OpenAI API 相容文档 https://platform.minimax.io/docs/api-reference/text-chat
# LiteLLM 通过 openai/<model> 路由到相容 Chat Completions 的 Base URL。
# LLM_CHANNELS=minimax
# LLM_MINIMAX_PROTOCOL=openai
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/v1
# LLM_MINIMAX_API_KEY=xxx
# LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
# LITELLM_MODEL=openai/MiniMax-M2.7
#
# 火山方舟 / 豆包（OpenAI Compatible，按實際开通地域調整 endpoint）
# 来源：火山方舟在线推理 / Responses API 文档 https://www.volcengine.com/docs/82379/2121998
# LiteLLM 通过 openai/<model> 路由到相容 Chat Completions 的 Base URL。
# LLM_CHANNELS=volcengine
# LLM_VOLCENGINE_PROTOCOL=openai
# LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_VOLCENGINE_API_KEY=xxx
# LLM_VOLCENGINE_MODELS=doubao-seed-1-6-251015,doubao-seed-1-6-thinking-251015
# LITELLM_MODEL=openai/doubao-seed-1-6-251015
#
# 硅基流动 SiliconFlow（OpenAI Compatible）
# 来源：官方模型列表 https://docs.siliconflow.cn/quickstart/models
# LLM_CHANNELS=siliconflow
# LLM_SILICONFLOW_PROTOCOL=openai
# LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_SILICONFLOW_API_KEY=sk-xxx
# LLM_SILICONFLOW_MODELS=deepseek-ai/DeepSeek-V3.2,Qwen/Qwen3-235B-A22B-Thinking-2507
# LITELLM_MODEL=openai/deepseek-ai/DeepSeek-V3.2
#
# OpenRouter（OpenAI Compatible）
# 来源：官方 Models API https://openrouter.ai/docs/api/api-reference/models/get-models
# LLM_CHANNELS=openrouter
# LLM_OPENROUTER_PROTOCOL=openai
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_API_KEY=sk-or-xxx
# LLM_OPENROUTER_MODELS=~anthropic/claude-sonnet-latest,~openai/gpt-latest
# LITELLM_MODEL=openai/~anthropic/claude-sonnet-latest

# 進階：模型路由 YAML 配置（可選，參考 docs/examples/litellm_config.example.yaml）
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# 搜尋引擎配置（用于獲取股票新闻）
# ===================================
# Bocha API Keys（中文搜尋最佳化，支援AI摘要，支援多个，逗号分隔）
# 獲取: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API Key（Coding Plan Web Search，支援多个，逗号分隔）
# 獲取: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API Keys（支援多个，逗号分隔）
TAVILY_API_KEYS=
# SerpAPI Keys（支援多个，逗号分隔）
SERPAPI_API_KEYS=
# Brave Search API Keys（支援多个，逗号分隔）
# 獲取: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG 实例地址（逗号分隔，私有部署无配額，需在 settings.yml 启用 format: json）
# 留空时預設自动从 searx.space 拉取公共实例；若不希望訪問公共实例，可将下方开关设为 false
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# 新闻时效与分析篩選配置
# ===================================
# 新闻策略窗口档位：ultra_short(1天) / short(3天) / medium(7天) / long(30天)
# 實際窗口 = min(策略窗口, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# 新闻最大时效（天），搜尋时限制结果在近期内，避免使用过时資訊
# NEWS_MAX_AGE_DAYS=3
# 乖离率閾值（%），偏离 MA5 超过此值提示不追高；强势趨勢股自动放宽到 1.5 倍
# BIAS_THRESHOLD=5.0

# ===================================
# Agent 策略对话配置（Web 对话页）
# ===================================
# 启用 Agent 策略对话（預設 false，内部统一命名为 skill）
# AGENT_MODE=true
# Agent 主模型（可選）：留空时继承主模型；无 provider 前綴会按 openai/<model> 解析
# AGENT_LITELLM_MODEL=
# Agent 最大推理步数上限（預設 10 时各子 Agent 按自身预设執行；高于預設 10 时所有子 Agent 统一采用该值；低于某子 Agent 預設值时会作为上限進行封顶）
# AGENT_MAX_STEPS=10
# 預設启用策略（逗号分隔），不配置时使用以下内置預設值
#
# 内置策略技能列表（可任意组合）：
#   bull_trend          — 多头趨勢（MA5>MA10>MA20 排列 + 低乖离率）
#   ma_golden_cross     — 均线金叉（MA5 上穿 MA10/MA20）
#   volume_breakout     — 放量突破（价格突破近期高点 + 成交量放大）
#   hot_theme           — 热点题材（政策/产业热点、板塊扩散与個股相關性）
#   event_driven        — 事件驱动（业绩、政策、订单、并购等催化事件）
#   growth_quality      — 成长质量（收入利潤、ROE、现金流与成长持续性）
#   expectation_repricing — 预期重估（业绩/政策/估值预期差修复或落空）
#   shrink_pullback     — 缩量回踩（回踩均线 + 量能萎缩，低吸点）
#   bottom_volume       — 底部放量（地量见地价，底部反转信号）
#   dragon_head         — 龙头策略（强势龙头，趨勢延续追涨）
#   one_yang_three_yin  — 一阳夹三阴（主力洗盘后强势反包形态）
#   box_oscillation     — 箱体震荡（區間高抛低吸）
#   chan_theory          — 缠论（缠中说禅理論：笔/线段/中枢）
#   wave_theory         — 波浪理論（艾略特波浪计数）
#   emotion_cycle       — 情绪周期（市场情绪高低点轮动）
#
# 留空时，系統会使用 metadata 里声明的主預設策略 skill（内置預設是 bull_trend）
# AGENT_SKILLS=
#
# 也可以手动指定一组策略：
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# 完整启用所有内置策略（两种写法等效）：
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# 自定义策略目錄（可選，放置自定义 YAML 策略文件；環境變數名沿用内部 skill 命名）
# AGENT_SKILL_DIR=./strategies

# Agent 架構模式（預設 single；multi 为多 Agent 编排模式）
# AGENT_ARCH=single

# Multi-Agent 编排模式（仅 AGENT_ARCH=multi 时有效）
# quick: 技术分析→决策（最快，约 2 次 LLM 呼叫）
# standard: 技术→情报→决策（預設）
# full: 技术→情报→风控→决策
# specialist: 技术→情报→风控→策略专家評估→决策
# AGENT_ORCHESTRATOR_MODE=standard

# Agent 執行逾時预算（秒，0 表示關閉；single-agent 用作整体循环预算，multi-agent 用作协作编排预算；預設 600）
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# 风控 Agent 是否可以否决買入信号（預設开启）
# AGENT_RISK_OVERRIDE=true

# 记忆与校准系統（追蹤历史準確率，自动调节置信度）
# AGENT_MEMORY_ENABLED=false

# 自动按回测表现加權策略意见
# AGENT_SKILL_AUTOWEIGHT=true

# 策略路由模式（auto=根据市场狀態自动选择 / manual=使用 AGENT_SKILLS 列表）
# AGENT_SKILL_ROUTING=auto

# 事件警報監控（schedule 模式后台轮询；触发后复用已配置通知渠道）
# 相容性说明：本节仅新增警報規則配置，不会修改模型名、provider、Base URL、LiteLLM 或 LLM 配置语义；回退只需關閉/移除事件監控配置。
# 支援規則：
#   price_cross          — 价格突破閾值，direction: above / below，欄位: price
#   price_change_percent — 漲跌幅閾值，direction: up / down，欄位: change_pct（单位：%）
#   volume_spike         — 成交量放大，欄位: multiplier（相對近 20 日均量倍数）
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]

# ===================================
# 通知渠道配置（可同时配置多个，全部推送）
# ===================================
#
# 【方式一】企业微信机器人
# 在企业微信群 -> 设置 -> 群机器人 -> 添加 -> 复制 Webhook 地址
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# 【方式二】飞书机器人
# 在飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# 如果机器人安全设置开启了“簽名校验”，需同步填写 secret
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# 如果机器人安全设置开启了“關鍵词”，需填写同一个關鍵词；系統会自动在每条訊息前补上
# FEISHU_WEBHOOK_KEYWORD=股票日报
# 注意：FEISHU_APP_ID / FEISHU_APP_SECRET 用于飞书应用、云文档或 Stream 模式，不会直接启用群 Webhook 推送
#
# 【方式三】Telegram 机器人（需同时配置两项）
# 1. 在 Telegram 找 @BotFather -> /newbot -> 獲取 Bot Token
# 2. 獲取 Chat ID：发訊息给 @userinfobot 或訪問 https://api.telegram.org/bot<token>/getUpdates
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# 【方式四】電郵推送（只需 2 项配置，SMTP 自动识别）
# 支援 QQ邮箱、163邮箱、Gmail 等支援 SMTP 授權码/基礎認證的邮箱
# Outlook / Exchange 若租户強制 OAuth2，当前版本暂不支援
# 1. 獲取授權码（以QQ邮箱为例）：设置 -> 账户 -> POP3/SMTP服務 -> 开启 -> 獲取授權码
# 2. 填写下面两项即可：
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # 可選，留空则发给自己
#
# 【方式四扩展】股票分組发往不同邮箱（Issue #268，可選）
# STOCK_LIST 决定實際分析範圍；STOCK_GROUP_N 仅决定電郵发给谁，建议始终写成 STOCK_LIST 的子集
# Telegram / 企业微信 / Webhook 等其他渠道仍会按完整 STOCK_LIST 推送，不会因为分組而拆分
# 当前倉庫預設 GitHub Actions daily_analysis workflow 不会自动注入任意编号的 STOCK_GROUP_N / EMAIL_GROUP_N
# 因此该能力适用于本機 .env、Docker，或其他已显式注入这些變數的執行環境
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# 【方式五】自定义 Webhook（支援多个，逗号分隔）
# 适用于：钉钉、Discord、Slack、Bark、自建服務等任意支援 POST JSON 的 Webhook
# 系統会自动识别常见服務并使用对应格式
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # 可選，用于需要認證的 Webhook (Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # 可選，全局 JSON body 模板，会覆盖 Bark/Slack/Discord 等自动 payload；推荐 $content_json/$title_json
# WEBHOOK_VERIFY_SSL=true   # 預設校验；影响讀取该配置的 webhook-style HTTPS 通知請求。设为 false 可支援自簽名证书。警告：禁用后存在 MITM 劫持風險，仅限可信内网
#
# 【方式六】Pushover 配置
# 注册Pushover账号，并建立应用Token https://pushover.net/apps/build
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# 【方式六扩展】ntfy 配置
# NTFY_URL 必须包含 topic path，例如 https://ntfy.sh/my-topic 或 https://self-hosted:port/my-topic
# 系統会解析 topic，并使用 ntfy JSON publish API 发送 Markdown 文本。
# NTFY_URL=
# NTFY_TOKEN=  # 可選，用于需要 Bearer Token 的 topic 或自建 ntfy server
#
# 【方式六扩展】Gotify 配置
# GOTIFY_URL 是 Gotify server base URL，不包含 /message；系統会拼接 /message 并用 X-Gotify-Key Header 发送 token。
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# 【方式七】PushPlus 配置（国内推送服務，推荐）
# 注册PushPlus账号并獲取Token https://www.pushplus.plus
# PUSHPLUS_TOKEN=
# 群組推送：填写群組編碼后，訊息推送给群組所有订阅使用者（一对多）
# PUSHPLUS_TOPIC=
#
# 【方式八】Discord 配置
# 支援两种方式：Webhook（推荐，配置簡單）和 Bot API（權限高）
# 
# 方式1：Discord Webhook（推荐，無需 Bot 账号）
# 在 Discord 频道设置 -> 集成 -> Webhook -> 新建 Webhook -> 复制 URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# 
# 方式2：Discord Bot API（需要 Bot 账号和频道 ID）
# 1. 建立 Bot：https://discord.com/developers/applications -> 新建应用 -> Bot -> 建立 Bot
# 2. 獲取 Bot Token：Bot 页面 -> 重置 Token
# 3. 獲取频道 ID：Discord 开启开发者模式 -> 右键频道 -> 复制 ID
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # 相容旧變數名，推荐改用 DISCORD_MAIN_CHANNEL_ID
# 如果你要接收 Discord Interaction / Webhook 回调，必须配置公钥用于验签
# 獲取方式：Discord Developer Portal -> General Information -> Public Key
# DISCORD_INTERACTIONS_PUBLIC_KEY=
# 
# 【方式九】Slack 配置
# 支援两种方式：Bot API（推荐）和 Incoming Webhook
# 同时配置时優先使用 Bot API，確保文本与图片发送到同一频道。
#
# 方式1：Slack Bot API（推荐，支援图片上傳）
# 1. 建立 Slack App：https://api.slack.com/apps -> Create New App
# 2. 添加 Bot Token Scopes：chat:write, files:write
# 3. 安裝到工作区并獲取 Bot Token (xoxb-...)
# 4. 獲取频道 ID：频道详情 -> 底部复制频道 ID
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# 方式2：Slack Incoming Webhook（配置簡單，不支援图片上傳）
# 在 Slack App 管理页面建立 Incoming Webhook -> 复制 URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# 【方式十】Server酱3 配置（国内推送服務，支援微信推送）
# 注册Server酱3账号并獲取SendKey https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# 【方式十一】AstrBot 配置
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # 可選，用于需要 Bearer Token 的 AstrBot Webhook
#
# 【進階配置】訊息长度限制（字节）
# 超过限制会自动分批发送，一般無需修改
# FEISHU_MAX_BYTES=20000    # 飞书限制约 20KB，預設 20000 字节
# WECHAT_MAX_BYTES=4000     # 企业微信限制 4096 字节，預設 4000 字节
#
# 【Markdown 转图片】(Issue #455)
# 对不支援 Markdown 的渠道，将报告转为图片发送，提升可读性
# 单股推送 + 图片：需同时配置 MARKDOWN_TO_IMAGE_CHANNELS 且安裝转图工具
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # 逗号分隔
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # 超过此长度不轉換，避免超大图片
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage(預設) | markdown-to-file(emoji 更好，需 npm i -g markdown-to-file)
# 转图工具：wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf)，或 markdown-to-file
#
# 【通知路由策略】(Issue #1200 P3)
# 預設留空：该类型通知发送到所有已配置渠道。填写后仅发送到列出的已配置渠道。
# 允許值：wechat,feishu,telegram,email,pushover,ntfy,gotify,pushplus,serverchan3,custom,discord,slack,astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# 【通知降噪機制】(Issue #1200 P4)
# 預設全部關閉；仅影响静态通知渠道，不影响机器人触发會話回执。
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # 同一稳定去重 key 在 TTL 内只发送一次；0 關閉
# NOTIFICATION_COOLDOWN_SECONDS=0       # 同一冷却 key 在窗口内限频；0 關閉
# NOTIFICATION_QUIET_HOURS=             # 静默时段，格式 HH:MM-HH:MM，支援跨午夜
# NOTIFICATION_TIMEZONE=                # 静默时段时区，如 Asia/Shanghai；留空跟随 TZ/系統本機时区
# NOTIFICATION_MIN_SEVERITY=            # info,warning,error,critical；留空保持现状
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # 预留配置；当前不会发送每日摘要
#
# 【实时行情预取】(Issue #455)
# PREFETCH_REALTIME_QUOTES=true   # 设为 false 可禁用，避免 efinance/akshare_em 全市场拉取；tushare 为单股介面，预取仅拉首股

# ===================================
# 单股推送配置（可選）
# ===================================
# 单股推送模式：每分析完一只股票立即推送，而不是汇总后推送
# SINGLE_STOCK_NOTIFY=false
#
# 报告类型：simple(精简)、full(完整)、brief(3-5句概括)
# Docker環境下如果推送内容不完整，可以设置为 full
# REPORT_TYPE=simple
# 报告輸出语言：zh(中文，預設) / en(英文)
# REPORT_LANGUAGE=zh
# 仅分析结果摘要：设为 true 时只推送汇总，不含個股详情
# REPORT_SUMMARY_ONLY=false
# 通知报告底部顯示本次分析使用的 LLM 模型名称；设为 false 可隱藏
# REPORT_SHOW_LLM_MODEL=true
#
# Report Engine P0 (Jinja2 / 完整性校验 / 历史对比)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# 個股分析与大盤复盘合併推送（預設 false），减少電郵数量、降低垃圾電郵風險
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# 分析间隔配置（可選）
# ===================================
# 個股分析和大盤分析之间的延遲时间（秒）
# 用于避免触发 Gemini 等 AI API 的限流
# ANALYSIS_DELAY=0

# 应用 AppKey（与 Webhook 模式共用）
DINGTALK_APP_KEY=xxxx
# 应用 AppSecret（与 Webhook 模式共用）
DINGTALK_APP_SECRET=xxxx
# 启用 Stream 模式
DINGTALK_STREAM_ENABLED=false

# 飞书应用机器人配置（用于 Stream Bot / 云文档模式，不会直接开启群 Webhook 推送）
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # 飞书应用 Secret，仅应用/Stream Bot/云文档模式使用；群通知推送请使用 FEISHU_WEBHOOK_URL
# 启用长連線模式
FEISHU_STREAM_ENABLED=false
# 飞书群机器人 Webhook 安全配置（仅 Webhook 推送模式使用）
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=股票日报

# 資料庫路徑
DATABASE_PATH=./data/stock_analysis.db
# SQLite 写入最佳化：文件库預設启用 WAL，降低批量写入和並行回写时的锁竞争
SQLITE_WAL_ENABLED=true
# SQLite 等锁逾時（毫秒）
SQLITE_BUSY_TIMEOUT_MS=5000
# SQLite 遇到 database is locked / database table is locked 时的最大重試次数
SQLITE_WRITE_RETRY_MAX=3
# SQLite 写入重試基礎退避时间（秒，按指數退避递增）
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# ===================================
# 回测配置（可選）
# ===================================
# 是否启用回测（true/false）
BACKTEST_ENABLED=true
# 回测評估窗口（交易日数）
BACKTEST_EVAL_WINDOW_DAYS=10
# 仅回测 N 天前的分析记录（避免当天/最近數據不完整）
BACKTEST_MIN_AGE_DAYS=14
# 回测引擎版本（当回测邏輯升級时用于区分结果）
BACKTEST_ENGINE_VERSION=v1
# 中性區間閾值（%），例如 2 表示 -2%~+2% 视为震荡
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === 定时工作配置 ===
# 是否启用定时工作（true/false）
SCHEDULE_ENABLED=false
# 每日執行时间（HH:MM 格式，24小时制）
SCHEDULE_TIME=18:00
# 定时模式啟動时是否立即執行一次分析（true/false）
# 若未显式设置，定时模式会沿用 RUN_IMMEDIATELY 的執行时覆盖语义以相容旧配置
SCHEDULE_RUN_IMMEDIATELY=true
# 非定时模式啟動时是否立即執行一次分析（true/false）
RUN_IMMEDIATELY=true
# 是否启用大盤复盘（true/false）
MARKET_REVIEW_ENABLED=true
# 大盤复盘市场区域：cn(A股)、hk(港股)、us(美股)、both(全部市场)，hk/us 适合仅关注港股/美股的使用者
# MARKET_REVIEW_REGION=cn
# 大盤复盘指數漲跌颜色：green_up=绿涨红跌（預設），red_up=红涨绿跌
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# 代理配置（可選）
# ===================================
# 是否启用代理（true/false，預設 false）
# 仅在本機开发環境生效，GitHub Actions 環境自动略過
USE_PROXY=false
# 代理服務器地址（預設 127.0.0.1）
PROXY_HOST=127.0.0.1
# 代理服務器端口（預設 10809）
PROXY_PORT=10809

# 系統配置
# 日誌目錄
LOG_DIR=./logs
# 日誌級別（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# LiteLLM 内部日誌級別（DEBUG/INFO/WARNING/ERROR/CRITICAL；預設 WARNING；排查内部流式/路由细节时可暫時设为 DEBUG）
# LITELLM_LOG_LEVEL=WARNING
# 最大並行執行緒数（建议保持低並行防封禁）
MAX_WORKERS=3
# 是否启用调试日誌
DEBUG=false

# ===================================
# WebUI 配置（可選）
# ===================================
# 是否預設啟動 WebUI（true/false，預設 false）
WEBUI_ENABLED=false
# WebUI 监听地址（預設 127.0.0.1；Docker/云服務器需设为 0.0.0.0 才能外网訪問，详见 docs/deploy-webui-cloud.md）
WEBUI_HOST=127.0.0.1
# WebUI 监听端口（預設 8000）
WEBUI_PORT=8000
# 啟動 Web 服務前是否自动构建前端（npm install && npm run build，預設 true）
WEBUI_AUTO_BUILD=true
# 单层可信反向代理（如 Nginx → App）下信任 X-Forwarded-For 獲取真实 IP，取最右值用于登录限流；多级代理/CDN 場景限流 key 可能退化为边缘代理 IP，需额外評估；直连公网时保持 false 防伪造
# TRUST_X_FORWARDED_FOR=false

# ===================================
# Web 登录認證（可選）
# ===================================
# 设为 true 启用密碼保护；首次訪問时在网页设置初始密碼，可在「系統设置 > 修改密碼」中修改
# 忘记密碼可在服務器執行: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # Session 有效期（小时）

# ===========================================
# 图片识别股票代碼（设置页「从图片添加」）
# ===========================================
# 单次請求逾時 60 秒；图片最大 5MB
# 需配置 GEMINI_API_KEY、ANTHROPIC_API_KEY 或 OPENAI_API_KEY 中至少一个（Vision 能力模型）

# ===========================================
# Data Fetcher Priority Configuration
# ===========================================
# Lower number = higher priority (tried first)
# Default priorities: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# For US stocks, set YFINANCE_PRIORITY=0 to use Yahoo Finance first

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # when eastmoney hosts are unreachable. Default: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx custom server (for intranet/deploy): use custom host instead of built-in public servers
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# Or multiple servers: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# Example: Prioritize Yahoo Finance for US stocks
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# 实时行情數據源優先级配置
# ===========================================
# 用于獲取量比、换手率、市盈率等实时數據
# 可選數據源（逗号分隔，按顺序嘗試）：
#   - tencent: 腾讯财经，有量比/换手率/PE/PB，单股查詢稳定（推荐首选）
#   - akshare_sina: 新浪财经，基本行情，无量比，但非常稳定
#   - efinance: 东财(efinance库)，有量比，全量拉取易被封
#   - akshare_em: 东财(akshare库)，數據最全，全量拉取易被封
#   - tushare: Tushare Pro，需要2000积分，數據全面（付费使用者推荐）
#
# 預設優先级：tencent > akshare_sina > efinance > akshare_em
# 如果有 Tushare Pro 高积分账号，可将 tushare 放在首位：
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# 是否启用实时行情（關閉后使用历史收盤价分析）
# ENABLE_REALTIME_QUOTE=true

# 盘中实时技术面：启用时用实时价计算 MA/多头排列（Issue #234）；關閉则用昨日收盤
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# 是否启用筹码分布（该介面不稳定，云端部署建议關閉）
# ENABLE_CHIP_DISTRIBUTION=true

# 是否启用基本面聚合（新增 P0 能力）
# ENABLE_FUNDAMENTAL_PIPELINE=true

# 基本面聚合效能与稳定性參數（单位：秒）
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=3.0
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# Portfolio P0: 匯入 / 風險 / 汇率降級配置
# ===========================================
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true

# 东财介面补丁：东财/Efinance/Akshare 东方财富介面頻繁失败（RemoteDisconnected、連線被關閉）时建议开启
# 开启后会注入 NID 令牌与隨機 User-Agent，降低被东财限流機率
# ENABLE_EASTMONEY_PATCH=false
